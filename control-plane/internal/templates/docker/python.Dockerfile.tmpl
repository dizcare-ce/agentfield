FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# --- OpenCode CLI (coding-agent harness) ---
# Installs Node.js + opencode-ai so app.harness(provider="opencode") works
# out of the box. The agent can delegate file-editing, shell, and multi-step
# coding tasks to OpenCode without any extra setup.
RUN apt-get update && apt-get install -y --no-install-recommends \
        nodejs npm git ca-certificates \
    && npm install -g opencode-ai@latest \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /app/requirements.txt

COPY . /app/

EXPOSE {{.AgentPort}}

CMD ["python", "main.py"]
